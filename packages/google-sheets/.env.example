MCP_GOOGLE_SHEETS_CLIENT_ID=your_google_oauth_client_id
MCP_GOOGLE_SHEETS_CLIENT_SECRET=your_google_oauth_client_secret
# Optional: instead of the two env vars above, point to a JSON file.
# MCP_GOOGLE_SHEETS_CLIENT_CREDENTIALS_PATH=C:\path\to\google-oauth-client.json

# Optional: try keytar first for token storage. Falls back to plaintext JSON.
MCP_GOOGLE_SHEETS_USE_KEYTAR=false
